            <hr/>
            <p> Maximum Temperature : <i><b><%= locals.Max_Temperature %> °F</b></i></p>
            <p> Minimum Temperature : <i><b><%= locals.Min_Temperature %> °F</b></i></p>
            <p>Average Temperature : <i><b><%= locals.Avg_Temp %> °F</b></i></p>
            <p>Humidity : <i><b><%= locals.Humidity %> %</b></i></p>
            <p>Windspeed : <i><b><%= locals.Wind_speed  %> knots</b></i></p>
        </div>
    </div>
    <div class="Future-Predictions">
        1 Week Prediction
    </div>
    <div class="PreviousDays-container">
        <div class="DayOne">
            <h2><%= locals.Date %></h2>
            <div class="icon1"><%= locals.icon %>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weather App</title>
<link href="styles/index.css" rel="stylesheet">
</head>
<body>
    <div class="WeatherWebsite">Weather Website</div>
    <div class="Main-Container">
        <div class="container">
        <form method="Post" action="/Submit">
            <div class="Location-Container">
                <label for="location">Location</label>
                <input type="text" name="location" id="location" class="Box" placeholder="Enter the Location">
            </div>
            <hr/>
            <label for="latitude">Latitude</label>
            <input type="number" name="latitude" id="latitude"  class="Box" placeholder="Enter the Latitude">
            <label for="longitude">Longitude</label>
            <input type="number" name="longitude" id="longitude" class="Box" placeholder="Enter the Longitude">
            <div class="Submit-Container">
                <input id="Submit" type="submit"  value="Submit">
            </div>
        </form>
        </div>
    </div>
    <div class="CurrentWeather">
        Current Weather
    </div>
    <div class="Climate">
        <div class="Parameters">
            <h2>Adress: <%= locals.Address %></h2>
            <h3 style="font-size: 1.2rem;">Date : <%= locals.Date %></h3>
